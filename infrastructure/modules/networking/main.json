{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "15494059103586251070"
    }
  },
  "parameters": {
    "vnetName": {
      "type": "string",
      "metadata": {
        "description": "Name of the virtual network."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all networking resources."
      }
    },
    "addressSpace": {
      "type": "string",
      "metadata": {
        "description": "Primary address space for the virtual network."
      }
    },
    "dnsServers": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Optional custom DNS servers for the VNET."
      }
    },
    "subnets": {
      "type": "array",
      "metadata": {
        "description": "Subnet resources already shaped for the Microsoft.Network virtualNetworks API."
      }
    },
    "routeTables": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Route table resources already shaped for the Microsoft.Network routeTables API."
      }
    }
  },
  "resources": [
    {
      "copy": {
        "name": "routeTableResources",
        "count": "[length(parameters('routeTables'))]"
      },
      "type": "Microsoft.Network/routeTables",
      "apiVersion": "2023-09-01",
      "name": "[parameters('routeTables')[copyIndex()].name]",
      "location": "[parameters('location')]",
      "properties": "[parameters('routeTables')[copyIndex()].properties]"
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-09-01",
      "name": "[parameters('vnetName')]",
      "location": "[parameters('location')]",
      "properties": "[union(createObject('addressSpace', createObject('addressPrefixes', createArray(parameters('addressSpace'))), 'subnets', parameters('subnets')), if(greater(length(parameters('dnsServers')), 0), createObject('dhcpOptions', createObject('dnsServers', parameters('dnsServers'))), createObject()))]"
    }
  ],
  "outputs": {
    "vnetId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks', parameters('vnetName'))]"
    },
    "subnetResourceIds": {
      "type": "array",
      "copy": {
        "count": "[length(parameters('subnets'))]",
        "input": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), parameters('subnets')[copyIndex()].name)]"
      }
    },
    "routeTableNames": {
      "type": "array",
      "copy": {
        "count": "[length(parameters('routeTables'))]",
        "input": "[parameters('routeTables')[copyIndex()].name]"
      }
    }
  }
}