{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "15913651802277173835"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "namePrefix": {
      "type": "string"
    },
    "corpLanPrefixes": {
      "type": "array"
    },
    "onPremFabricPrefixes": {
      "type": "array"
    },
    "storageProviderPrefix": {
      "type": "string"
    },
    "databaseProviderPrefix": {
      "type": "string"
    },
    "serviceMeshSubnetPrefix": {
      "type": "string"
    },
    "internetEgressFqdns": {
      "type": "array"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[format('{0}-firewall-policy', parameters('namePrefix'))]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "firewallPolicyName": {
            "value": "[format('{0}-afw-policy', parameters('namePrefix'))]"
          },
          "ruleCollectionGroupName": {
            "value": "[format('{0}-fast-rcg', parameters('namePrefix'))]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "networkRuleCollections": {
            "value": [
              {
                "name": "fast-private-connectivity",
                "priority": 100,
                "ruleCollectionType": "FirewallPolicyFilterRuleCollection",
                "action": {
                  "type": "Allow"
                },
                "rules": [
                  {
                    "name": "mesh-to-storage",
                    "ruleType": "NetworkRule",
                    "ipProtocols": [
                      "TCP"
                    ],
                    "sourceAddresses": [
                      "[parameters('serviceMeshSubnetPrefix')]"
                    ],
                    "destinationAddresses": [
                      "[parameters('storageProviderPrefix')]"
                    ],
                    "destinationPorts": [
                      "443"
                    ]
                  },
                  {
                    "name": "mesh-to-postgresql",
                    "ruleType": "NetworkRule",
                    "ipProtocols": [
                      "TCP"
                    ],
                    "sourceAddresses": [
                      "[parameters('serviceMeshSubnetPrefix')]"
                    ],
                    "destinationAddresses": [
                      "[parameters('databaseProviderPrefix')]"
                    ],
                    "destinationPorts": [
                      "5432"
                    ]
                  }
                ]
              },
              {
                "name": "fast-corporate-ingress",
                "priority": 200,
                "ruleCollectionType": "FirewallPolicyFilterRuleCollection",
                "action": {
                  "type": "Allow"
                },
                "rules": [
                  {
                    "name": "corporate-to-ui-and-apis",
                    "ruleType": "NetworkRule",
                    "ipProtocols": [
                      "TCP"
                    ],
                    "sourceAddresses": "[parameters('corpLanPrefixes')]",
                    "destinationAddresses": [
                      "[parameters('serviceMeshSubnetPrefix')]"
                    ],
                    "destinationPorts": [
                      "80",
                      "443"
                    ]
                  }
                ]
              },
              {
                "name": "fast-file-transfer",
                "priority": 300,
                "ruleCollectionType": "FirewallPolicyFilterRuleCollection",
                "action": {
                  "type": "Allow"
                },
                "rules": [
                  {
                    "name": "mesh-to-onprem-file-transfer",
                    "ruleType": "NetworkRule",
                    "ipProtocols": [
                      "TCP"
                    ],
                    "sourceAddresses": [
                      "[parameters('serviceMeshSubnetPrefix')]"
                    ],
                    "destinationAddresses": "[parameters('onPremFabricPrefixes')]",
                    "destinationPorts": [
                      "443"
                    ]
                  }
                ]
              }
            ]
          },
          "applicationRuleCollections": {
            "value": [
              {
                "name": "fast-internet-egress",
                "priority": 400,
                "ruleCollectionType": "FirewallPolicyFilterRuleCollection",
                "action": {
                  "type": "Allow"
                },
                "rules": [
                  {
                    "name": "mesh-to-m365-and-sharepoint",
                    "ruleType": "ApplicationRule",
                    "sourceAddresses": [
                      "[parameters('serviceMeshSubnetPrefix')]"
                    ],
                    "targetFqdns": "[parameters('internetEgressFqdns')]",
                    "terminateTLS": false,
                    "protocols": [
                      {
                        "protocolType": "Https",
                        "port": 443
                      }
                    ]
                  }
                ]
              }
            ]
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "8734701051543743620"
            }
          },
          "parameters": {
            "firewallPolicyName": {
              "type": "string",
              "metadata": {
                "description": "Name of the Azure Firewall Policy to create."
              }
            },
            "location": {
              "type": "string",
              "defaultValue": "[resourceGroup().location]",
              "metadata": {
                "description": "Azure region for the firewall policy resources."
              }
            },
            "ruleCollectionGroupName": {
              "type": "string",
              "defaultValue": "[format('{0}-rcg', parameters('firewallPolicyName'))]",
              "metadata": {
                "description": "Rule collection group name that contains the FAST connectivity rules."
              }
            },
            "networkRuleCollections": {
              "type": "array",
              "defaultValue": [],
              "metadata": {
                "description": "Network rule collections already shaped for the firewall policy rule collection group resource."
              }
            },
            "applicationRuleCollections": {
              "type": "array",
              "defaultValue": [],
              "metadata": {
                "description": "Application rule collections already shaped for the firewall policy rule collection group resource."
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.Network/firewallPolicies",
              "apiVersion": "2023-09-01",
              "name": "[parameters('firewallPolicyName')]",
              "location": "[parameters('location')]",
              "properties": {
                "sku": {
                  "tier": "Standard"
                },
                "threatIntelMode": "Alert"
              }
            },
            {
              "type": "Microsoft.Network/firewallPolicies/ruleCollectionGroups",
              "apiVersion": "2023-09-01",
              "name": "[format('{0}/{1}', parameters('firewallPolicyName'), parameters('ruleCollectionGroupName'))]",
              "properties": {
                "priority": 200,
                "ruleCollections": "[concat(parameters('networkRuleCollections'), parameters('applicationRuleCollections'))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Network/firewallPolicies', parameters('firewallPolicyName'))]"
              ]
            }
          ],
          "outputs": {
            "firewallPolicyId": {
              "type": "string",
              "value": "[resourceId('Microsoft.Network/firewallPolicies', parameters('firewallPolicyName'))]"
            },
            "ruleCollectionGroupId": {
              "type": "string",
              "value": "[resourceId('Microsoft.Network/firewallPolicies/ruleCollectionGroups', parameters('firewallPolicyName'), parameters('ruleCollectionGroupName'))]"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "firewallPolicyId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', format('{0}-firewall-policy', parameters('namePrefix'))), '2025-04-01').outputs.firewallPolicyId.value]"
    }
  }
}